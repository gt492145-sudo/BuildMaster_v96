# 本機或反代後面聽 127.0.0.1；VPS/容器對外請改 0.0.0.0（並開防火牆）
HOST=127.0.0.1
PORT=8787
AUTH_SECRET=change-this-buildmaster-secret
BUILDMASTER_ACCESS_CODE=ChangeMe2026!
BUILDMASTER_ACCESS_LEVEL=standard
DEFAULT_ADMIN_ACCOUNT=owner
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_LEVEL=pro
# Optional App Review/demo account that can log in even if the member DB is unavailable.
# Configure these to exactly match the credentials supplied in App Store Connect.
APP_REVIEW_DEMO_ACCOUNT=
APP_REVIEW_DEMO_PASSWORD=
APP_REVIEW_DEMO_LEVEL=pro
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ENDPOINT=https://api.openai.com/v1/chat/completions
IBM_QUANTUM_API_KEY=
IBM_QUANTUM_ENDPOINT=https://api.quantum-computing.ibm.com/v2/jobs
# PostgreSQL connection: use DATABASE_URL or the DB_* fields below.
DATABASE_URL=
DB_HOST=your-cloud-sql-public-ip
DB_PORT=5432
DB_NAME=construction_master
DB_USER=cm_app
DB_PASSWORD=change-this-db-password
DB_SSL=require
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=10000
# Optional: legacy JSON file path for one-time migration.
LEGACY_DATA_FILE=./data/app-db.json
# 上線時請加上正式網域（含 https），例如：https://wenwenming.com,https://www.wenwenming.com
ALLOWED_ORIGINS=http://127.0.0.1:8787,http://localhost:8787,http://127.0.0.1:5500,http://localhost:5500

# --- 會員收費（Stripe 網頁／Webhook）---
# 後台建立 Checkout 或 Payment Link，成功導回網址請帶參數：?stripe_session={CHECKOUT_SESSION_ID}
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
# 各方案對應的 Stripe Price ID（price_xxx）
STRIPE_PRICE_BASIC=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PRO=
# Payment Link 完整網址（登入畫面會顯示按鈕）
STRIPE_PAYMENT_LINK_BASIC=
STRIPE_PAYMENT_LINK_STANDARD=
STRIPE_PAYMENT_LINK_PRO=

# --- Apple App 內購（收據驗證，上架用）---
# App Store Connect → App 內購 → 共用密鑰（舊版 verifyReceipt 用）
APPLE_APP_STORE_SHARED_SECRET=
# 與 App Store Connect 產品 ID 一致
APPLE_IAP_PRODUCT_BASIC=
APPLE_IAP_PRODUCT_STANDARD=
APPLE_IAP_PRODUCT_PRO=

# 付費兌換後 JWT：一次性付款未綁訂閱週期時的最長有效秒數（預設 90 天）
BILLING_SESSION_TTL_SECONDS=7776000
# JWT 單次核發上限（避免異常過長；訂閱制仍受 Stripe／Apple 到期日截斷）
BILLING_SESSION_MAX_TTL_SECONDS=31622400
